{
  "name": "gizmo-ai-unlimited-hearts",
  "version": "0.2.0",
  "private": true,
  "description": "MV3 extension that bypasses the out-of-hearts modal on app.gizmo.ai/quiz",
  "scripts": {
    "dev": "plasmo dev",
    "dev:firefox": "plasmo dev --target=firefox-mv3",
    "build": "plasmo build",
    "build:firefox": "plasmo build --target=firefox-mv3",
    "package": "plasmo package",
    "package:firefox": "plasmo package --target=firefox-mv3",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test \"tests/**/*.test.ts\""
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.40",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "plasmo": "^0.90.5",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "lmdb",
      "msgpackr-extract",
      "sharp"
    ]
  },
  "manifest": {
    "name": "Gizmo AI Unlimited Hearts",
    "description": "Bypasses the out-of-hearts modal on Gizmo AI quizzes.",
    "author": "Alexey Fedorov",
    "host_permissions": [
      "https://app.gizmo.ai/*"
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "gizmo-ai-unlimited-hearts@gizmoai.local"
      }
    }
  }
}
